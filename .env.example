# Copy to `.env` and fill in real values. Do not commit `.env`.

# DeepInfra OpenAI-compatible API (required)
# https://deepinfra.com/dash/api_keys
DEEPINFRA_TOKEN=

# Postgres (defaults match chatbot/config.py)
# Docker Compose overrides POSTGRES_HOST for the chatbot container to `postgres`.
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpass
POSTGRES_DB=pgdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# API server
APP_HOST=0.0.0.0
APP_PORT=8000

# Backend tuning — omit to use defaults baked into chatbot/config.py (same values as below).
# DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1
# DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3.2
# REQUEST_TIMEOUT_SECONDS=600
# CHAT_ARCHIVE_RETENTION_DAYS=30

# Web / Compose only — not read by Python Settings; compose sets BACKEND_URL for the web container.
# For `npm run dev` in web/, put BACKEND_URL in web/.env.local instead.
# NEXT_PORT=3000
# BACKEND_URL=http://127.0.0.1:8000
# BACKEND_PROXY_TIMEOUT_MS=300000
